{
  "name": "snapforge",
  "version": "1.0.4",
  "description": "Premium, cross-platform screenshot utility",
  "main": "./out/main/index.js",
  "author": "kingsleyasah",
  "license": "MIT",
  "scripts": {
    "dev": "env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "build": "electron-vite build",
    "build:mac": "npm run build && electron-builder --mac --config electron-builder.config.js",
    "build:win": "npm run build && electron-builder --win --config electron-builder.config.js",
    "publish:mac": "npm run build && electron-builder --mac --publish always --config electron-builder.config.js",
    "preview": "env -u ELECTRON_RUN_AS_NODE electron-vite preview"
  },
  "dependencies": {
    "fabric": "^7.2.0",
    "lucide-react": "^0.358.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tesseract.js": "^5.1.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/node": "^20.11.20",
    "@types/react": "^18.2.58",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.3.3",
    "vite": "^5.1.4"
  }
}
