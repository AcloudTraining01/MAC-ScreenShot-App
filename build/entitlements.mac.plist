<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!-- Required for Electron's JIT compilation -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <!-- Required for Electron's unsigned executable memory -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Required for loading third-party libraries (Tesseract, etc.) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- NOTE: com.apple.security.device.screen-recording is intentionally
         omitted.  We use the system `screencapture` binary for capture, which
         handles its own TCC access.  Declaring the entitlement here would
         cause macOS to register SnapForge in the Screen Recording privacy
         list and trigger permission prompts that become stale on ad-hoc
         rebuilds. -->
    <!-- Network access for OCR model downloads -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- File system access for saving screenshots -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>
  </dict>
</plist>
